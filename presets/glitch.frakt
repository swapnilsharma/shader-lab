{
  "version": "1",
  "name": "glitch",
  "canvas": { "background": "#000000" },
  "layers": [
    { "type": "scanlines", "name": "Scanlines", "properties": {
      "count": 140, "dark": 0.28, "soft": 0.28, "scroll": 1, "scrollspd": 0.45
    }},
    { "type": "chromatic-aberration", "name": "Chromatic Aberration", "properties": {
      "spread": 0.018, "angle": 0
    }},
